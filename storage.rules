rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Apps folder (apks, app screenshots, app logos)
    match /apps/{appId}/{fileName} {
      // Anyone can read downloaded media
      allow read: if true;
      // Only admins can upload files
      allow write: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
    
    // Fallback default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
