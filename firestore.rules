rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admins collection: only readable by the server or checking if auth uid exists
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only manageable from Firebase Console directly
    }

    // Apps collection: anyone can read apps, only admins can write
    match /apps/{appId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Users collection: storing FCM tokens and other data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
